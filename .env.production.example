# ---------- Infra ----------
POSTGRES_USER=meeting_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=meeting_ai

# ---------- App Core ----------
DATABASE_URL=postgresql+psycopg2://meeting_user:change_me_strong_password@db:5432/meeting_ai
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- Upload ----------
UPLOADS_DIR=backend/uploads
UPLOAD_MAX_SIZE_BYTES=26214400
UPLOAD_ALLOWED_EXTENSIONS=.wav,.mp3,.m4a,.mp4,.mpeg,.mpga,.webm,.ogg
UPLOAD_ALLOWED_MIME_TYPES=audio/wav,audio/x-wav,audio/wave,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/m4a,audio/webm,audio/ogg,application/ogg,video/mp4

# ---------- Processing ----------
# placeholder | openai
PROCESSING_PROVIDER=placeholder
PROCESSING_FALLBACK_TO_PLACEHOLDER=true
PROCESS_SYNC_WHEN_PROVIDER_PLACEHOLDER=false

# Optional (needed only when PROCESSING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_SUMMARY_TRANSCRIPT_CHAR_LIMIT=12000

# ---------- Celery / Redis ----------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=300
CELERY_TASK_TIME_LIMIT_SECONDS=600
CELERY_FALLBACK_TO_INLINE=true
